# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps Map ID (Cloud Console > Map Management, type: JavaScript / Vector).
# Required by the issues map: AdvancedMarkerElement only renders on a map that
# has a Map ID. Optional — the build succeeds without it and the map falls back
# to a message state. Note that setting a Map ID makes Google ignore any inline
# `styles` array; the basemap style is then configured in the Cloud Console.
GOOGLE_MAPS_MAP_ID=your_google_maps_map_id_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# API Configuration (defaults to local backend)
API_URL=http://localhost:8080/api